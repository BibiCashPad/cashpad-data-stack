# Copier ce fichier en `.env` et adapter au besoin.
# En dev local, ces valeurs sont OK telles quelles.

# Postgres warehouse (utilisé par tous les services du docker-compose)
POSTGRES_USER=data
POSTGRES_PASSWORD=data

# ─────────────────────────────────────────────────────────────
# Airbyte sync (utilisé par scripts/airbyte_push.py)
# Cf. scripts/README.md pour la procédure de récupération.
# ─────────────────────────────────────────────────────────────
AIRBYTE_API_URL=http://localhost:8000/api
AIRBYTE_WORKSPACE_ID=
AIRBYTE_CLIENT_ID=
AIRBYTE_CLIENT_SECRET=
AIRBYTE_CONNECTOR_NAME=Sellsy V2
AIRBYTE_MANIFEST_PATH=airbyte/sellsy_v2.yaml
